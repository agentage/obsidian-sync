{
  "name": "obsidian-memory",
  "version": "0.1.0",
  "description": "Agentage Memory — Obsidian plugin. One memory, every AI, owned by you.",
  "private": true,
  "type": "module",
  "main": "main.js",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "type-check": "tsc --noEmit -skipLibCheck",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf main.js *.map coverage",
    "couchdb:up": "docker compose up -d",
    "couchdb:down": "docker compose down",
    "couchdb:reset": "docker compose down -v",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "verify": "npm run type-check && npm run lint && npm run format:check && npm run test && npm run build"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "agentage",
    "mcp",
    "sync"
  ],
  "author": "agentage",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.7",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "obsidian": "latest",
    "prettier": "^3.4.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}

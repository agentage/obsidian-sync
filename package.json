{
  "name": "obsidian-vault",
  "version": "0.1.0",
  "description": "agentage Vault — Obsidian plugin. One vault, every AI, owned by you.",
  "private": true,
  "type": "module",
  "main": "main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "verify": "npm run lint && npm run build"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "agentage",
    "mcp",
    "sync"
  ],
  "author": "agentage",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "obsidian": "latest",
    "prettier": "^3.4.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0"
  }
}
